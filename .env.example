# ============================================================
# Deal Finder Pro — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Amazon Product Advertising API ---
# Sign up: https://affiliate-program.amazon.com
# Then: https://webservices.amazon.com/paapi5/documentation/
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=dealfinder-20

# --- eBay Browse API ---
# Sign up: https://developer.ebay.com/signin
EBAY_APP_ID=
EBAY_SECRET=

# --- Walmart Affiliate API ---
# Sign up: https://developer.walmart.com
WALMART_API_KEY=
WALMART_AFFILIATE_ID=

# --- Affiliate Link Tags ---
# These get appended to outbound product URLs
EBAY_CAMPAIGN_ID=

# --- Email Notifications (SMTP) ---
# Use SendGrid, Gmail, or any SMTP provider
# SendGrid: https://signup.sendgrid.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=alerts@yourdomain.com

# --- SMS Notifications (Twilio) ---
# Sign up: https://www.twilio.com/try-twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+15551234567

# --- Google Analytics ---
# Get your Measurement ID from https://analytics.google.com
# Then replace G-XXXXXXXXXX in templates/index.html and templates/landing.html
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Scheduler ---
# How often to run background scans (in minutes)
SCAN_INTERVAL=60
